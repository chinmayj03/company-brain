# ══════════════════════════════════════════════════════════════════════════════
# Company Brain — Environment Configuration
# Copy to .env and fill in the values you need.
# ══════════════════════════════════════════════════════════════════════════════

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Controls which LLM backend the AI service uses.
# Switch at any time — no code changes needed.
#
#   ollama     → local models via Ollama Docker container (DEFAULT, no keys needed)
#   anthropic  → Claude via Anthropic API (requires ANTHROPIC_API_KEY)
#   openai     → GPT-4o via OpenAI API (requires OPENAI_API_KEY)
#
LLM_PROVIDER=groq

# ── Groq (fast free LLM API — 500–1000 tok/s) ────────────────────────────────
# Get free key at: https://console.groq.com/keys  (no card needed)
GROQ_API_KEY=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

# Per-role model overrides (optional — defaults shown)
# GROQ_MODEL_FAST=llama-3.1-8b-instant
# GROQ_MODEL_BALANCED=meta-llama/llama-4-scout-17b-16e-instruct
# GROQ_MODEL_SYNTHESIS=openai/gpt-oss-120b
# GROQ_MODEL_REASONING=qwen/qwen3-32b
# GROQ_MODEL_QUERY=openai/gpt-oss-120b

# ── Ollama (local inference, optional fallback) ───────────────────────────────
OLLAMA_HOST=http://localhost:11434

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# Used when LLM_PROVIDER=anthropic
# Create at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Per-role model overrides (optional — defaults shown)
# ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001
# ANTHROPIC_MODEL_SYNTHESIS=claude-opus-4-6

# ── OpenAI ───────────────────────────────────────────────────────────────────
# Used when LLM_PROVIDER=openai
OPENAI_API_KEY=

# For Azure OpenAI or other compatible endpoints (leave blank for standard OpenAI)
# OPENAI_BASE_URL=https://your-resource.openai.azure.com/

# Per-role model overrides (optional — defaults shown)
# OPENAI_MODEL_FAST=gpt-4o-mini
# OPENAI_MODEL_SYNTHESIS=gpt-4o

# ── GitHub (optional — for PR description enrichment) ────────────────────────
# Create at: https://github.com/settings/tokens (repo:read scope)
GITHUB_TOKEN=

# ── JWT (shared between backend and AI service) ──────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=dev-secret-change-in-production

# ── Jira (optional) ──────────────────────────────────────────────────────────
# JIRA_BASE_URL=https://yourcompany.atlassian.net
# JIRA_EMAIL=you@yourcompany.com
# JIRA_API_TOKEN=

# ── Linear (optional) ────────────────────────────────────────────────────────
# LINEAR_API_KEY=lin_api_...

# ── AWS (leave as-is for local dev — LocalStack is used) ─────────────────────
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1
