# ══════════════════════════════════════════════════════════════════════════════
# Company Brain — Environment Configuration
# Copy to .env and fill in the values you need.
# ══════════════════════════════════════════════════════════════════════════════

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Controls which LLM backend the AI service uses.
# Switch at any time — no code changes needed.
#
#   ollama     → local models via Ollama Docker container (DEFAULT, no keys needed)
#   anthropic  → Claude via Anthropic API (requires ANTHROPIC_API_KEY)
#   openai     → GPT-4o via OpenAI API (requires OPENAI_API_KEY)
#
LLM_PROVIDER=ollama

# ── Ollama (local inference) ──────────────────────────────────────────────────
# Used when LLM_PROVIDER=ollama
# Default host works when Ollama runs in docker-compose.infra.yml
OLLAMA_HOST=http://localhost:11434

# Per-role model overrides (optional — defaults shown)
# OLLAMA_MODEL_FAST=llama3.1:8b
# OLLAMA_MODEL_BALANCED=deepseek-coder-v2:16b
# OLLAMA_MODEL_SYNTHESIS=deepseek-r1:14b
# OLLAMA_MODEL_REASONING=deepseek-r1:14b
# OLLAMA_MODEL_QUERY=deepseek-r1:14b

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# Used when LLM_PROVIDER=anthropic
# Create at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Per-role model overrides (optional — defaults shown)
# ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001
# ANTHROPIC_MODEL_SYNTHESIS=claude-opus-4-6

# ── OpenAI ───────────────────────────────────────────────────────────────────
# Used when LLM_PROVIDER=openai
OPENAI_API_KEY=

# For Azure OpenAI or other compatible endpoints (leave blank for standard OpenAI)
# OPENAI_BASE_URL=https://your-resource.openai.azure.com/

# Per-role model overrides (optional — defaults shown)
# OPENAI_MODEL_FAST=gpt-4o-mini
# OPENAI_MODEL_SYNTHESIS=gpt-4o

# ── GitHub (optional — for PR description enrichment) ────────────────────────
# Create at: https://github.com/settings/tokens (repo:read scope)
GITHUB_TOKEN=

# ── JWT (shared between backend and AI service) ──────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=dev-secret-change-in-production

# ── Jira (optional) ──────────────────────────────────────────────────────────
# JIRA_BASE_URL=https://yourcompany.atlassian.net
# JIRA_EMAIL=you@yourcompany.com
# JIRA_API_TOKEN=

# ── Linear (optional) ────────────────────────────────────────────────────────
# LINEAR_API_KEY=lin_api_...

# ── AWS (leave as-is for local dev — LocalStack is used) ─────────────────────
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1

# ══════════════════════════════════════════════════════════════════════════════
# Optimization Directive — Retrieval & Observability Stack
# All optional. Services run locally via docker-compose.infra.yml.
# ══════════════════════════════════════════════════════════════════════════════

# ── Qdrant (vector store) — starts automatically with `make up` ──────────────
# Default connects to local container; override for Qdrant Cloud.
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=                        # leave blank for local dev

# ── Code Embeddings — tiered (first available provider wins) ─────────────────
#
# Tier 1 — Voyage AI (best quality, paid ~$0.00012 / 1K tokens)
#   Create at: https://dash.voyageai.com/  (free tier: 50M tokens/month)
VOYAGE_API_KEY=
#
# Tier 2 — FastEmbed local (FREE, no key needed, auto-downloads ~130MB model)
#   Enabled automatically when VOYAGE_API_KEY is blank and fastembed is installed.
#   Model: jinaai/jina-embeddings-v2-base-code (code-specific, 768 dims)
#   Install: pip install "qdrant-client[fastembed]"   ← already in pyproject.toml
#
# Tier 3 — Ollama local (FREE, requires Ollama running on OLLAMA_HOST)
#   Pull the model once: ollama pull nomic-embed-text
#   Falls through to this if both Voyage and FastEmbed are unavailable.
#
# Tier 4 — BM25-only mode (no dense retrieval, still works fine for most repos)
#   Active when none of the above are available.

# ── Langfuse (LLM observability) — SELF-HOSTED = FREE ────────────────────────
# Langfuse runs locally in docker-compose.infra.yml — no cloud account needed.
# 1. Run `make up` to start Langfuse at http://localhost:3001
# 2. Open http://localhost:3001, create an account + project
# 3. Copy the keys from Project Settings → API Keys
# Without these keys, cost/token telemetry is logged to stdout only (still works).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3001

# ── Hybrid search tuning (optional — safe to leave at defaults) ──────────────
# BM25_TOP_K=50          # BM25 candidate pool before reranking
# DENSE_TOP_K=50         # Vector candidate pool before reranking
# RERANK_TOP_K=10        # Final results after cross-encoder reranking
# HYBRID_SEARCH_ENABLED=true
