# ─────────────────────────────────────────────────────────────────────────────
# company-brain-ai  —  environment configuration
#
# Copy this file to .env and fill in the values you need.
# Only the variables for your chosen LLM_PROVIDER are required.
#
# IMPORTANT — subscription plans vs API access:
#   Claude Max ($100–200/month) and OpenAI Pro ($200/month) are chat
#   subscriptions. They do NOT include API credits.
#   API keys and billing are managed separately:
#     Anthropic API  → https://console.anthropic.com   (add credit card)
#     OpenAI API     → https://platform.openai.com     (add credit card)
#
#   FREE OPTIONS (no credit card required):
#     Groq       → https://console.groq.com   (Llama 3.3 70B, 300+ tok/s)
#     OpenRouter → https://openrouter.ai      (30+ free models incl. DeepSeek-R1)
# ─────────────────────────────────────────────────────────────────────────────


# ── LLM Provider ─────────────────────────────────────────────────────────────
# Valid values: ollama | anthropic | openai | groq | openrouter
#
#  groq        → FREE cloud API, 300+ tok/s, Llama 3.3 70B (BEST for testing)
#  openrouter  → FREE cloud API, 30+ models, DeepSeek-R1 free
#  ollama      → local models, no API key, free but slower
#  anthropic   → Claude models (best quality, paid)
#  openai      → GPT models (paid)


# ── Groq (FREE — recommended for testing) ────────────────────────────────────
# Sign up at: https://console.groq.com/keys  (no credit card required)
#
# Current model lineup (April 2026) with API model IDs:
#
#   API model ID                                  Speed      Best for
#   ─────────────────────────────────────────── ─────────── ─────────────────────
#   openai/gpt-oss-20b                          1,000 tok/s  Fast extraction (FAST role)
#   meta-llama/llama-4-scout-17b-16e-instruct     750 tok/s  Tool use, vision (BALANCED)
#   openai/gpt-oss-120b                           500 tok/s  Synthesis & queries
#   qwen/qwen3-32b                                400 tok/s  Reasoning & gap detection
#   llama-3.3-70b-versatile                       280 tok/s  Fallback, proven reliable
#   llama-3.1-8b-instant                          560 tok/s  Ultra-fast fallback
#
# All models have 131K context window.
# For 500 files: stays within free tier if run in stages (entity pass then synthesis).

# Recommended role assignment — fastest model for high-volume extraction,
# strongest for synthesis and reasoning (low-volume passes).
GROQ_MODEL_FAST=llama-3.1-8b-instant
GROQ_MODEL_BALANCED=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_MODEL_SYNTHESIS=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_MODEL_REASONING=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_MODEL_QUERY=meta-llama/llama-4-scout-17b-16e-instruct

# Reduce concurrency to stay within tok/min rate limits.
# MAX_ENTITY_EXTRACTION_CONCURRENCY=3
# MAX_CONTEXT_SYNTHESIS_CONCURRENCY=2


# ── OpenRouter (FREE — 30+ models) ───────────────────────────────────────────
# Sign up at: https://openrouter.ai/keys  (no credit card for free models)
#
# Free models available (April 2026) — append :free to model name:
#   meta-llama/llama-3.1-8b-instruct:free     ← fast, extraction tasks
#   meta-llama/llama-3.3-70b-instruct:free    ← best free quality
#   deepseek/deepseek-r1:free                 ← strong reasoning (use for gap detection)
#   deepseek/deepseek-r1-distill-llama-70b:free
#   google/gemma-3-27b-it:free
#   mistralai/mistral-7b-instruct:free
#
# Rate limits on free models: ~20 req/min, 200 req/day per model.
# For 500 files, spread across multiple free models or run overnight.
OPENROUTER_API_KEY=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

# Using stronger models for synthesis/reasoning, lighter for extraction:
OPENROUTER_MODEL_FAST=google/gemma-3-27b-it:free
OPENROUTER_MODEL_BALANCED=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_MODEL_SYNTHESIS=deepseek/deepseek-r1:free
OPENROUTER_MODEL_REASONING=deepseek/deepseek-r1:free
OPENROUTER_MODEL_QUERY=meta-llama/llama-3.3-70b-instruct:free

# Reduce concurrency for OpenRouter free tier:
# MAX_ENTITY_EXTRACTION_CONCURRENCY=2
# MAX_CONTEXT_SYNTHESIS_CONCURRENCY=1


# ── Anthropic ─────────────────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=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

# Model per task role — ALL set to haiku for minimum cost during validation.
# haiku: $1.00 in / $5.00 out per MTok — cheapest Claude model.
# Switch BALANCED/SYNTHESIS/REASONING to sonnet-4-6 only when quality matters.
ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_BALANCED=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_SYNTHESIS=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_REASONING=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_QUERY=claude-haiku-4-5-20251001

# Set to true to use Anthropic's Batch API (async, up to 24hr, 50% cheaper).
# Good for full indexing runs that don't need real-time feedback.
ANTHROPIC_USE_BATCH_API=false


# ── OpenAI ────────────────────────────────────────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Pricing (April 2026, per million tokens  in / out):
#   gpt-4o-mini   →  $0.15 / $0.60    ← cheapest option (~$1.80/run for 500 files)
#   gpt-4o        →  $2.50 / $10.00   ← ~$30/run for 500 files
#
# Context window: 128K tokens (vs Claude's 200K — affects MAX_INPUT_TOKENS below)
OPENAI_MODEL_FAST=gpt-4o-mini
OPENAI_MODEL_BALANCED=gpt-4o
OPENAI_MODEL_SYNTHESIS=gpt-4o
OPENAI_MODEL_REASONING=gpt-4o
OPENAI_MODEL_QUERY=gpt-4o

# Optional — set for Azure OpenAI or a compatible endpoint
# OPENAI_BASE_URL=https://your-resource.openai.azure.com/


# ── Ollama (local, no API key) ────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL_FAST=llama3.1:8b
OLLAMA_MODEL_BALANCED=deepseek-coder-v2:16b
OLLAMA_MODEL_SYNTHESIS=deepseek-r1:14b
OLLAMA_MODEL_REASONING=deepseek-r1:14b
OLLAMA_MODEL_QUERY=deepseek-r1:14b

# Context window passed to Ollama (prompt + response tokens combined).
# Increase if you see HTTP 500 errors on large files.
# Decrease (e.g. 2048) if you're low on VRAM.
OLLAMA_NUM_CTX=3072


# ── Context window & output token budgets ─────────────────────────────────────
#
# MAX_INPUT_TOKENS: hard cap on prompt size sent to any LLM.
#   Claude models: 200K context → use 120_000 (leaves room for response)
#   gpt-4o / gpt-4o-mini: 128K context → use 100_000
#   Groq Llama 3.3 70B: 128K context → use 100_000
#   Groq Mixtral: 32K context → use 28_000
#   OpenRouter free models: varies (128K for Llama, 64K for DeepSeek-R1 free)
#   Ollama (depends on model, controlled separately by OLLAMA_NUM_CTX)
MAX_INPUT_TOKENS=120000

# Per-stage output limits. Raise if you see truncated JSON responses.
# The old hardcoded default for entity extraction was 512 — far too low for
# files with many classes. 2048 is the recommended minimum.
MAX_TOKENS_ENTITY_EXTRACTION=2048
MAX_TOKENS_INTENT_SYNTHESIS=1024
MAX_TOKENS_RELATIONSHIP=2048
MAX_TOKENS_CONTEXT_SYNTHESIS=1024
MAX_TOKENS_GAP_DETECTION=4096
MAX_TOKENS_QUERY=2048


# ── Concurrency ───────────────────────────────────────────────────────────────
# Cloud APIs (Anthropic / OpenAI): run multiple LLM calls in parallel.
# Groq free tier: 3–5 (tok/min limited, not req/min limited).
# OpenRouter free tier: 1–2 (strict per-model req limits).
# Ollama: always 1 (single GPU, sequential).
# Raise these if you have high API tier rate limits.
# Lower them if you're hitting 429 rate-limit errors.
MAX_ENTITY_EXTRACTION_CONCURRENCY=10
MAX_CONTEXT_SYNTHESIS_CONCURRENCY=5


# ── Infrastructure ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://companybrain:companybrain@localhost:5432/companybrain
REDIS_URL=redis://localhost:6379/0

# GitHub token — optional, only needed for PR/issue enrichment
GITHUB_TOKEN=ghp_...

# JWT secret — change this in production
JWT_SECRET=dev-secret-change-in-production


# ── AWS / SQS (LocalStack for local dev) ─────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
SQS_ENDPOINT=http://localhost:4566
SQS_INGESTION_QUEUE=company-brain-ingestion

# ── Active provider override ──────────────────────────────────────────────────
# ── Active provider: Anthropic only ──────────────────────────────────────────
LLM_PROVIDER=anthropic
LLM_FALLBACK_CHAIN=

GROQ_MODEL_FAST=llama-3.1-8b-instant
GROQ_MODEL_BALANCED=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_MODEL_SYNTHESIS=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_MODEL_REASONING=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_MODEL_QUERY=meta-llama/llama-4-scout-17b-16e-instruct

MAX_INPUT_TOKENS=100000
MAX_ENTITY_EXTRACTION_CONCURRENCY=1
MAX_CONTEXT_SYNTHESIS_CONCURRENCY=1
BACKEND_URL=http://localhost:8080
BACKEND_API_KEY=dev-local-key
